# FinApply.ai Environment Variables
# Copy this file to .env.local and fill in your values

# ── Supabase (Required) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Gmail SMTP (Required for email notifications) ──
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# ── Google Gemini (Required for AI evaluation) ──
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxx

# ── Internal Auth (Required for auto-evaluation pipeline) ──
# Used for server-to-server calls between /api/simulations → /api/admin/evaluate
# If not set, falls back to SUPABASE_SERVICE_ROLE_KEY
ADMIN_API_SECRET=a-strong-random-secret-here

# ── App Configuration ──
NEXT_PUBLIC_APP_URL=https://fin-apply-ai.vercel.app
MAKE_WEBHOOK_SECRET=your-webhook-secret

# ── Inngest (Required for reliable evaluation processing) ──
# Sign up at: https://app.inngest.com
# Event Key: used by the app to send events
# Signing Key: used to verify incoming webhook calls
INNGEST_EVENT_KEY=your_inngest_event_key
INNGEST_SIGNING_KEY=your_inngest_signing_key
