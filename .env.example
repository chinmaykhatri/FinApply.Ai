# FinApply.ai Environment Variables
# Copy this file to .env.local and fill in your values

# ── Supabase (Required) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Resend (Required for email notifications) ──
RESEND_API_KEY=re_xxxxxxxxxxxx

# ── Google Gemini (Required for AI evaluation) ──
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxx

# ── App Configuration ──
NEXT_PUBLIC_APP_URL=https://finapply-ai-delta.vercel.app
MAKE_WEBHOOK_SECRET=your-webhook-secret
