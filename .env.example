# FinApply.ai Environment Variables
# Copy this file to .env.local and fill in your values

# ── Supabase (Required) ──
# Get from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Resend (Required for email notifications) ──
# Get from: https://resend.com/api-keys (free: 100 emails/day)
RESEND_API_KEY=re_xxxxxxxxxxxx

# ── Anthropic (Required for AI evaluation) ──
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ── App Configuration ──
NEXT_PUBLIC_APP_URL=https://finapply.vercel.app
MAKE_WEBHOOK_SECRET=your-webhook-secret
