{
  "name": "FinApply — Send FISS Report",
  "flow": [
    {
      "id": 1,
      "module": "gateway:CustomWebHook",
      "version": 1,
      "parameters": {
        "hook": null
      },
      "mapper": {},
      "metadata": {
        "designer": {
          "x": 0,
          "y": 0,
          "name": "Report Webhook"
        },
        "restore": {},
        "expect": [
          { "name": "candidate_name", "type": "text", "label": "Candidate Name" },
          { "name": "candidate_email", "type": "text", "label": "Candidate Email" },
          { "name": "fiss_score", "type": "number", "label": "FISS Score" },
          { "name": "report_url", "type": "text", "label": "Report URL" },
          { "name": "pdf_url", "type": "text", "label": "PDF URL" },
          { "name": "evaluator_summary", "type": "text", "label": "Evaluator Summary" },
          { "name": "standout_strength", "type": "text", "label": "Standout Strength" },
          { "name": "critical_gap", "type": "text", "label": "Critical Gap" },
          { "name": "loom_url", "type": "text", "label": "Loom Walkthrough URL" }
        ]
      }
    },
    {
      "id": 2,
      "module": "email:ActionSendEmail",
      "version": 3,
      "parameters": {
        "account": null
      },
      "mapper": {
        "to": "{{1.candidate_email}}",
        "subject": "Your FISS Score Report is Ready — {{1.fiss_score}}/100",
        "html": "<div style=\"font-family: -apple-system, sans-serif; max-width: 600px; margin: 0 auto; background: #000; color: #fff; padding: 40px; border-radius: 16px;\">\n  <div style=\"text-align: center; padding-bottom: 24px; border-bottom: 1px solid #222;\">\n    <p style=\"font-size: 11px; color: #2563EB; letter-spacing: 3px; font-weight: 600; margin: 0;\">FINAPPLY.AI</p>\n  </div>\n  <div style=\"padding: 32px 0; text-align: center;\">\n    <p style=\"font-size: 11px; color: #666; letter-spacing: 2px; margin: 0 0 12px;\">YOUR FISS SCORE</p>\n    <div style=\"display: inline-block; width: 100px; height: 100px; border-radius: 50%; border: 3px solid #2563EB; line-height: 100px; text-align: center; margin-bottom: 16px;\">\n      <span style=\"font-size: 36px; font-weight: 700;\">{{1.fiss_score}}</span>\n    </div>\n    <p style=\"font-size: 11px; color: #666; margin: 0;\">out of 100</p>\n  </div>\n  <div style=\"background: #111; border-radius: 12px; padding: 20px; margin: 16px 0; border: 1px solid #222;\">\n    <p style=\"font-size: 12px; color: #666; margin: 0 0 6px;\">EVALUATOR SUMMARY</p>\n    <p style=\"font-size: 14px; color: #ccc; line-height: 1.6; margin: 0; font-style: italic;\">\"{{1.evaluator_summary}}\"</p>\n  </div>\n  <div style=\"display: flex; gap: 12px; margin: 16px 0;\">\n    <div style=\"flex: 1; padding: 14px; background: rgba(22,163,74,0.06); border-left: 3px solid #16A34A; border-radius: 0 8px 8px 0;\">\n      <p style=\"font-size: 10px; color: #16A34A; letter-spacing: 1px; margin: 0 0 4px; font-weight: 600;\">STRENGTH</p>\n      <p style=\"font-size: 12px; color: #999; line-height: 1.4; margin: 0;\">{{1.standout_strength}}</p>\n    </div>\n  </div>\n  <div style=\"margin: 16px 0;\">\n    <div style=\"padding: 14px; background: rgba(217,119,6,0.06); border-left: 3px solid #D97706; border-radius: 0 8px 8px 0;\">\n      <p style=\"font-size: 10px; color: #D97706; letter-spacing: 1px; margin: 0 0 4px; font-weight: 600;\">AREA TO DEVELOP</p>\n      <p style=\"font-size: 12px; color: #999; line-height: 1.4; margin: 0;\">{{1.critical_gap}}</p>\n    </div>\n  </div>\n  {{if(1.loom_url; \"<div style='margin: 16px 0; padding: 14px; background: rgba(139,92,246,0.06); border-left: 3px solid #8B5CF6; border-radius: 0 8px 8px 0;'><p style='font-size: 10px; color: #8B5CF6; letter-spacing: 1px; margin: 0 0 4px; font-weight: 600;'>🎥 VIDEO WALKTHROUGH</p><p style='font-size: 12px; color: #999; margin: 0;'>Your evaluator recorded a personalized walkthrough.</p><a href='\" & 1.loom_url & \"' style='display: inline-block; margin-top: 10px; padding: 8px 20px; background: #8B5CF6; color: #fff; border-radius: 100px; text-decoration: none; font-size: 12px; font-weight: 500;'>Watch Walkthrough →</a></div>\"; \"\")}}\n  <div style=\"text-align: center; margin-top: 24px;\">\n    <a href=\"{{1.report_url}}\" style=\"display: inline-block; padding: 12px 32px; background: #2563EB; color: #fff; border-radius: 100px; text-decoration: none; font-size: 14px; font-weight: 500; margin-bottom: 12px;\">View Full Report →</a>\n    <br/>\n    <a href=\"{{1.pdf_url}}\" style=\"font-size: 12px; color: #666; text-decoration: underline;\">Download PDF Report</a>\n  </div>\n  <div style=\"margin-top: 32px; padding-top: 20px; border-top: 1px solid #222; text-align: center;\">\n    <p style=\"font-size: 11px; color: #444; margin: 0;\">Evaluated by human + AI collaboration</p>\n    <p style=\"font-size: 10px; color: #333; margin-top: 4px;\">FinApply.ai · FISS Score v1.0 · Not a guarantee of employment outcomes</p>\n  </div>\n</div>"
      },
      "metadata": {
        "designer": {
          "x": 300,
          "y": 0,
          "name": "Send FISS Report Email"
        }
      }
    }
  ],
  "metadata": {
    "version": 1,
    "scenario": {
      "roundtrips": 1,
      "maxErrors": 3,
      "autoCommit": true,
      "autoCommitTriggerLast": true,
      "sequential": false
    },
    "designer": {
      "orphans": []
    }
  }
}
